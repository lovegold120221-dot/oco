# AI
GEMINI_API_KEY=               # Google Gemini API key

# Supabase (PostgreSQL)
SUPABASE_URL=                 # https://<ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=     # Supabase anon key
SUPABASE_SERVICE_ROLE_KEY=    # Supabase service role key
DATABASE_URL=                 # Optional: full PostgreSQL connection string

# WhatsApp (Meta for Developers Cloud API)
WHATSAPP_ACCESS_TOKEN=        # Permanent user access token or temporary token from developers.facebook.com
WHATSAPP_PHONE_NUMBER_ID=     # Phone number ID (numeric string) from Meta Developer console
WHATSAPP_BUSINESS_ACCOUNT_ID= # WhatsApp Business Account ID (optional)

# Firebase
FIREBASE_PROJECT_ID=gen-lang-client-0836251512
FIREBASE_REGION=asia-southeast1
GOOGLE_CLIENT_ID=             # OAuth client ID
GOOGLE_APPS_SCRIPT_URL=       # Apps Script web app URL

# Search
GOOGLE_SEARCH_API_KEY=        # Custom Search API key
GOOGLE_SEARCH_ENGINE_ID=      # Custom Search engine ID

# Server
PORT=3000
